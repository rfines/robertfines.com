generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AlbumFormat {
  vinyl
  cd
  cassette
  digital
  other
}

model Album {
  id            String      @id @default(cuid())
  title         String
  artist        String
  year          Int?
  genre         String?
  format        AlbumFormat
  label         String?
  coverImageUrl String?
  rating        Int?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([artist])
  @@index([genre])
}
